---
import { t } from '@utils/i18n'
import type { Lang } from '@utils/i18n'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const tr = t(lang)
const stayUrl = lang === 'ru' ? '/ru/stay' : '/stay'
const eatUrl = lang === 'ru' ? '/ru/eat' : '/eat'
const liveUrl = lang === 'ru' ? '/ru/community' : '/community'
const locationUrl = lang === 'ru' ? '/ru/location' : '/location'
---

<footer class="bg-night border-t border-white/10">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-20 py-16 md:py-24">
    <div class="flex flex-col md:flex-row justify-between items-start gap-12">
      <div>
        <p class="text-cream font-bold text-sm tracking-logo uppercase mb-3">BORN TO BE</p>
        <p class="text-cream/50 text-[13px] tracking-card max-w-[280px] leading-relaxed">{tr.footer.tagline}</p>
      </div>
      <div class="flex flex-col md:flex-row gap-12">
        <div>
          <p class="text-[11px] font-medium tracking-caption uppercase text-cream/40 mb-4">{tr.footer.navigate}</p>
          <div class="flex flex-col gap-3">
            <a href={stayUrl} class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">{tr.nav.stay}</a>
            <a href={eatUrl} class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">{tr.nav.eat}</a>
            <a href={liveUrl} class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">{tr.nav.live}</a>
            <a href={locationUrl} class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">{tr.nav.location}</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-medium tracking-caption uppercase text-cream/40 mb-4">{tr.footer.connect}</p>
          <div class="flex flex-col gap-3">
            <a href="https://instagram.com/borntobe.complex" target="_blank" rel="noopener" class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">Instagram</a>
            <a href="https://t.me/borntobe_complex" target="_blank" rel="noopener" class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">Telegram</a>
            <a href="https://wa.me/6281234567890" target="_blank" rel="noopener" class="text-cream/70 text-[13px] tracking-card hover:text-gold transition-colors duration-300">WhatsApp</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-medium tracking-caption uppercase text-cream/40 mb-4">{tr.footer.location}</p>
          <p class="text-cream/70 text-[13px] tracking-card leading-relaxed whitespace-pre-line">{tr.footer.locationText}</p>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-cream/30 text-[12px] tracking-card">{tr.footer.copyright}</p>
      <p class="text-cream/30 text-[12px] tracking-hero uppercase">{tr.footer.slogan}</p>
    </div>
  </div>
</footer>
