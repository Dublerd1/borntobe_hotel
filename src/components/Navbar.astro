---
import { t, getAlternateUrl } from '@utils/i18n'
import type { Lang } from '@utils/i18n'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const tr = t(lang)
const altLang = lang === 'en' ? 'ru' : 'en'
const langLabel = lang === 'en' ? 'RU' : 'EN'
const currentPath = Astro.url.pathname
const altUrl = getAlternateUrl(currentPath, altLang)
const stayUrl = lang === 'ru' ? '/ru/stay' : '/stay'
const eatUrl = lang === 'ru' ? '/ru/eat' : '/eat'
const liveUrl = lang === 'ru' ? '/ru/community' : '/community'
const locationUrl = lang === 'ru' ? '/ru/location' : '/location'
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-[background] duration-300">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-20 h-20 flex items-center justify-between">
    <a href={lang === 'ru' ? '/ru/' : '/'} class="text-white font-bold text-sm tracking-logo uppercase transition-colors duration-300">
      BORN TO BE
    </a>
    <div class="hidden md:flex items-center gap-10">
      <a href={stayUrl} class="text-white/85 text-[13px] font-medium tracking-menu uppercase hover:text-white transition-opacity duration-300">{tr.nav.stay}</a>
      <a href={eatUrl} class="text-white/85 text-[13px] font-medium tracking-menu uppercase hover:text-white transition-opacity duration-300">{tr.nav.eat}</a>
      <a href={liveUrl} class="text-white/85 text-[13px] font-medium tracking-menu uppercase hover:text-white transition-opacity duration-300">{tr.nav.live}</a>
      <a href={locationUrl} class="text-white/85 text-[13px] font-medium tracking-menu uppercase hover:text-white transition-opacity duration-300">{tr.nav.location}</a>
    </div>
    <div class="hidden md:flex items-center gap-6">
      <a href={altUrl} class="text-white/70 text-[13px] font-normal tracking-menu uppercase hover:text-white transition-colors duration-300">{langLabel}</a>
      <a href={stayUrl} class="bg-cream text-dark text-[13px] font-semibold tracking-[1.5px] uppercase px-6 py-2.5 hover:bg-gold hover:text-cream transition-colors duration-300 cursor-pointer">{tr.nav.book}</a>
    </div>
    <button id="mobileMenuBtn" class="md:hidden text-white cursor-pointer" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div id="mobileMenu" class="fixed inset-0 z-60 bg-night flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
  <button id="mobileMenuClose" class="absolute top-6 right-6 text-cream cursor-pointer" aria-label="Close menu">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <a href={stayUrl} class="text-cream text-2xl font-light tracking-section uppercase">{tr.nav.stay}</a>
  <a href={eatUrl} class="text-cream text-2xl font-light tracking-section uppercase">{tr.nav.eat}</a>
  <a href={liveUrl} class="text-cream text-2xl font-light tracking-section uppercase">{tr.nav.live}</a>
  <a href={locationUrl} class="text-cream text-2xl font-light tracking-section uppercase">{tr.nav.location}</a>
  <div class="mt-4">
    <a href={stayUrl} class="bg-cream text-dark text-[13px] font-semibold tracking-caption uppercase px-10 py-4 hover:bg-gold hover:text-cream transition-colors duration-300">{tr.nav.book}</a>
  </div>
  <a href={altUrl} class="text-cream/50 text-sm tracking-caption uppercase mt-4">{langLabel}</a>
</div>

<script>
  const navbar = document.getElementById('navbar')!
  const mobileMenuBtn = document.getElementById('mobileMenuBtn')!
  const mobileMenu = document.getElementById('mobileMenu')!
  const mobileMenuClose = document.getElementById('mobileMenuClose')!

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 80)
  })

  mobileMenuBtn.addEventListener('click', () => {
    mobileMenu.classList.remove('opacity-0', 'pointer-events-none')
  })
  mobileMenuClose.addEventListener('click', () => {
    mobileMenu.classList.add('opacity-0', 'pointer-events-none')
  })
</script>

<style>
  nav.scrolled {
    background: #141414 !important;
  }
</style>
