---
import BaseLayout from '@layouts/BaseLayout.astro'
import Hero from '@components/Hero.astro'

const lang = 'ru'
---

<BaseLayout
  title="Born To Be Complex — Бутик-отель в Перереnan, Бали"
  description="Экосистема стиля жизни в Перереnan, Бали. Апартаменты, кафе, комьюнити, руфтоп. От $55/ночь."
  lang={lang}
  canonical="https://borntobecomplex.com/ru/"
>
  <Hero lang={lang} backgroundImage="/content/photos/01-hero/night_facade_pool_float.jpg" />

  <!-- Stay Preview — split: photo left, text right -->
  <section class="bg-bg">
    <div class="max-w-[1440px] mx-auto flex flex-col md:flex-row">
      <div class="md:w-1/2">
        <img
          src="content/photos/01-hero/townhouse_bedroom_rice_terrace.jpg"
          alt="Интерьер апартамента с видом на рисовые террасы"
          class="w-full h-full object-cover"
          style="aspect-ratio: 4/5;"
          loading="lazy"
        />
      </div>
      <div class="md:w-1/2 flex items-center px-6 md:px-16 lg:px-24 py-20 md:py-32">
        <div>
          <p class="text-[11px] font-medium tracking-caption uppercase text-muted mb-4">Перереnan, Бали</p>
          <h2 class="text-[32px] md:text-[44px] font-bold tracking-section uppercase mb-6">Номера</h2>
          <div class="w-12 h-[2px] bg-gold mb-8"></div>
          <p class="text-muted text-[16px] md:text-[17px] leading-relaxed mb-10 max-w-[440px]">
            9 уникальных апартаментов и таунхаусов. Каждый со своим характером, видом и историей. От уютных студий до просторных двухэтажных таунхаусов с видом на рисовые террасы.
          </p>
          <a href="/ru/stay" class="inline-block bg-dark text-cream text-[13px] font-semibold tracking-caption uppercase px-10 py-4 hover:bg-gold transition-colors duration-300 cursor-pointer">
            Смотреть номера
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Eat Preview — full-bleed photo background -->
  <section class="relative min-h-[600px] md:min-h-[700px] flex items-center bg-cover bg-center"
    style="background-image: url('content/photos/05-cafe/woman_matcha_healthy_spread.jpg');">
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);"></div>
    <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-16 lg:px-24 py-20">
      <div class="max-w-[480px]">
        <p class="text-[11px] font-medium tracking-caption uppercase text-white/50 mb-4">Здоровая еда с душой</p>
        <h2 class="text-[32px] md:text-[44px] font-bold tracking-section uppercase text-cream mb-6">Кафе</h2>
        <div class="w-12 h-[2px] bg-gold mb-8"></div>
        <p class="text-cream/70 text-[16px] md:text-[17px] leading-relaxed mb-10">
          Смузи-боулы, свежие соки, авторские блюда. Здоровое питание как стиль жизни, а не диета. Открыто для гостей и всех желающих.
        </p>
        <a href="/ru/eat" class="inline-block border border-cream/70 text-cream text-[13px] font-semibold tracking-caption uppercase px-10 py-4 hover:bg-gold hover:border-gold transition-colors duration-300 cursor-pointer">
          Меню
        </a>
      </div>
    </div>
  </section>

  <!-- Community Preview — split: text left, photo right -->
  <section class="bg-bg">
    <div class="max-w-[1440px] mx-auto flex flex-col-reverse md:flex-row">
      <div class="md:w-1/2 flex items-center px-6 md:px-16 lg:px-24 py-20 md:py-32">
        <div>
          <p class="text-[11px] font-medium tracking-caption uppercase text-muted mb-4">Больше чем отель</p>
          <h2 class="text-[32px] md:text-[44px] font-bold tracking-section uppercase mb-6">Жизнь</h2>
          <div class="w-12 h-[2px] bg-gold mb-8"></div>
          <p class="text-muted text-[16px] md:text-[17px] leading-relaxed mb-10 max-w-[440px]">
            Руфтоп-ивенты с видом на вулкан, фитнес, коворкинг, бренд Born To Be Wear. Комьюнити единомышленников, которые выбрали жить, а не существовать.
          </p>
          <a href="/ru/community" class="inline-block bg-dark text-cream text-[13px] font-semibold tracking-caption uppercase px-10 py-4 hover:bg-gold transition-colors duration-300 cursor-pointer">
            Комьюнити
          </a>
        </div>
      </div>
      <div class="md:w-1/2">
        <img
          src="content/photos/06-rooftop/rooftop_volcano_panorama.jpg"
          alt="Руфтоп с видом на вулкан"
          class="w-full h-full object-cover"
          style="aspect-ratio: 4/5;"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</BaseLayout>
